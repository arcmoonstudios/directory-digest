{
  "name": "directory-digest",
  "displayName": "Directory Digest",
  "publisher": "ArcMoonStudios",
  "author": "Lord Xyn",
  "description": "Directory Digest is a Visual Studio Code extension that adds powerful directory content management capabilities.",
  "version": "0.1.0",
  "type": "commonjs",
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#2F1754",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "directory",
    "file management",
    "content organization",
    "text processing",
    "file combining"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "files": [
    "out/**/*"
  ],
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -w -p . --outDir out",
    "lint": "eslint ./src --ext .ts --fix",
    "clean-lock": "rm -f .vscode-test/user-data/Crashpad/pending/*.lock",
    "pretest": "yarn clean-lock && yarn compile-tests && yarn compile && yarn lint",
    "test": "node ./out/test/runTest.js"
  },
  "contributes": {
    "commands": [
      {
        "command": "extension.appendDirectoryContent",
        "title": "Directory Digest: Combine Files",
        "category": "Directory Digest"
      },
      {
        "command": "extension.appendAllToOutputDir",
        "title": "Directory Digest: Create 0L Structure",
        "category": "Directory Digest"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "when": "explorerResourceIsFolder",
          "command": "extension.appendDirectoryContent",
          "group": "7_modification"
        },
        {
          "when": "explorerResourceIsFolder",
          "command": "extension.appendAllToOutputDir",
          "group": "7_modification"
        }
      ]
    },
    "configuration": {
      "type": "object",
      "title": "Directory Digest Configuration",
      "properties": {
        "directoryDigest.appendContent.excludedFileExtensions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            ".env",
            ".ini",
            ".cfg",
            ".config",
            ".lock",
            ".toml",
            ".yaml",
            ".yml",
            ".exe",
            ".dll",
            ".so",
            ".dylib",
            ".class",
            ".pyc",
            ".pyo",
            ".pyd",
            ".obj",
            ".o",
            ".a",
            ".lib",
            ".out",
            ".rlib",
            ".rmeta",
            ".jar",
            ".war",
            ".ear",
            ".egg",
            ".wheel",
            ".whl",
            ".gem",
            ".ttf",
            ".otf",
            ".woff",
            ".woff2",
            ".eot",
            ".swp",
            ".cache",
            ".tmp",
            ".temp",
            ".swo",
            ".bin",
            ".dat",
            ".db",
            ".sqlite",
            ".sqlite3",
            ".mdb",
            ".pdb",
            ".ilk",
            ".exp",
            ".map",
            ".pdf",
            ".doc",
            ".docx",
            ".xls",
            ".xlsx",
            ".ppt",
            ".pptx",
            ".jpg",
            ".jpeg",
            ".png",
            ".gif",
            ".bmp",
            ".ico",
            ".mp3",
            ".mp4",
            ".wav",
            ".avi",
            ".mov",
            ".zip",
            ".rar",
            ".7z",
            ".tar",
            ".gz",
            ".tgz",
            ".bz2",
            ".iml",
            ".idea",
            ".project",
            ".classpath",
            ".settings",
            ".vscode",
            ".vs",
            ".suo",
            ".user",
            ".sln",
            ".xcodeproj",
            ".xcworkspace",
            ".DS_Store"
          ],
          "description": "File extensions to exclude from processing"
        },
        "directoryDigest.appendContent.excludedDirectories": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "0L",
            ".git",
            ".svn",
            ".hg",
            ".bzr",
            "CVS",
            "node_modules",
            "target",
            "build",
            "dist",
            "bin",
            "obj",
            "out",
            "__pycache__",
            ".pytest_cache",
            ".tox",
            ".venv",
            "venv",
            "env",
            "Lib",
            "Scripts",
            "site-packages",
            "classes",
            "META-INF",
            "WEB-INF",
            "bower_components",
            "jspm_packages",
            ".npm",
            ".yarn",
            "vendor/bundle",
            ".bundle",
            "packages",
            "Debug",
            "Release",
            "x86",
            "x64",
            "AnyCPU",
            ".idea",
            ".vscode",
            ".vs",
            ".settings",
            ".project",
            ".classpath",
            "logs",
            "log",
            "tmp",
            "temp",
            "cache",
            ".cache",
            "docs",
            "doc",
            "documentation",
            "coverage",
            ".nyc_output",
            "htmlcov",
            ".github",
            ".gitlab",
            ".circleci",
            ".jenkins",
            ".docker",
            ".history",
            ".grunt",
            ".sass-cache",
            "bower_components",
            "jspm_packages",
            "public/hot",
            "storage",
            "compiled",
            "uploads",
            "vendor",
            "Cargo.lock",
            "Cargo.toml"
          ],
          "description": "Directories to exclude from processing"
        }
      }
    }
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.9",
    "@types/node": "20.x",
    "@types/vscode": "^1.95.0",
    "@typescript-eslint/eslint-plugin": "^8.14.0",
    "@typescript-eslint/parser": "^8.14.0",
    "@vscode/test-electron": "^2.3.8",
    "eslint": "^8.56.0",
    "glob": "^9.3.5",
    "mocha": "^10.2.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "winston": "^3.11.0",
    "glob": "^9.3.5"
  }
}